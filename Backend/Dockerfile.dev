FROM node:22-alpine
WORKDIR /app

# Install deps from manifests — source is mounted at runtime, not copied
COPY package*.json tsconfig.json prisma.config.ts ./
COPY prisma ./prisma/

RUN npm ci

# Generate Prisma client so /app/prisma/generated is populated in the image
# (the named volume in compose inherits this on first start)
RUN npx prisma generate

EXPOSE 3000

COPY docker-entrypoint.dev.sh ./
RUN chmod +x docker-entrypoint.dev.sh

ENTRYPOINT ["./docker-entrypoint.dev.sh"]
