# PostgreSQL — used by the db service and injected into backend as DATABASE_URL
POSTGRES_DB=infoskjerm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# better-auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=https://site.example.com

# TQ api keys
TQ_API_KEY=change-me-to-tq-api-key
TQ_API_SECRET=change-me-to-tq-api-secret
TQ_BACKEND_URL=https://site.example.com